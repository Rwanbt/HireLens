# Normalize line endings: always LF in the repo, regardless of OS.
* text=auto eol=lf

# Force LF for source files
*.rs      text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.sh      text eol=lf

# Binary — no conversion
*.png     binary
*.jpg     binary
*.ico     binary
*.pdf     binary
